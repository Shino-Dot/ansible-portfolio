warn_list:
  - yaml[truthy]
  - yaml[empty-lines]
  - yaml[fqcn]
  - fqcn[action-core]
  - name[casing]

skip_list:
  - risky-file-permissions
  - no-changefd-when
  - ignore-errors
  - var-naming[no-role-prefix]
  - no-changed-when
  - command-instead-of-module
  - package-latest

exclude_paths:
  - .github/
