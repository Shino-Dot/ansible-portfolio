global:
  resolve_timeout: 5m

route:
  receiver: 'slack'
  group_by: ['alertname', 'instance']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h

receivers:
  - name: 'slack'
    slack_configs:
      - api_url: '{{ alertmanager_slack_webhook_url }}'
        channel: '{{ alertmanager_slack_channel }}'
        title: 'Alert'
        text: 'An alert has been fired'

